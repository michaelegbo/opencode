{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paddie Studio",
  "identifier": "io.paddie.studio",
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/prod/32x32.png",
      "icons/prod/128x128.png",
      "icons/prod/128x128@2x.png",
      "icons/prod/icon.icns",
      "icons/prod/icon.ico"
    ],
    "windows": {
      "signCommand": {
        "cmd": "powershell",
        "args": ["-ExecutionPolicy", "Bypass", "-File", "../../../script/sign-windows.ps1", "%1"]
      },
      "nsis": {
        "installerIcon": "icons/prod/icon.ico",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/io.paddie.studio.metainfo.xml": "release/appstream.metainfo.xml"
        }
      },
      "rpm": {
        "compression": {
          "type": "none"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0NEVFQUU3MDE2NjFEMTcKUldRWEhXWUI1K3BPZEMvTkJUSkF0ZUgrQjY4MTZKNGE0a0U5dFZuRkY0LzRNZTdLUTNzVGJlczcK",
      "endpoints": ["https://github.com/michaelegbo/paddie-studio-ui-coder/releases/latest/download/latest.json"]
    }
  }
}
